<view class="hero">
  <image class="icon" src="/assets/briba-icon.svg" mode="aspectFit" />
  <view>
    <view class="title">BriBa</view>
    <view class="muted">导入学习包，开始精听。</view>
  </view>
</view>

<view class="card welcome">
  <view class="section-title">{{projects.length > 0 ? '继续学习' : '开始学习'}}</view>
  <view class="muted" wx:if="{{projects.length > 0}}">已导入 {{projects.length}} 个学习库。小程序端只负责离线学习。</view>
  <view class="muted" wx:else>请先上传电脑端导出的 BriBa Pack。</view>
  <button wx:if="{{projects.length > 0}}" class="primary" bindtap="continueLast">继续学习</button>
  <button class="secondary" bindtap="choosePack">{{projects.length > 0 ? '上传新的学习包' : '上传学习包'}}</button>
  <button wx:if="{{projects.length > 0}}" class="plain" bindtap="clearPack">清空本地学习包</button>
</view>

<view wx:if="{{projects.length > 0}}" class="section-title list-title">开始学习</view>
<view wx:for="{{projects}}" wx:key="id" class="card project" data-index="{{index}}" bindtap="openProject">
  <view class="project-title">{{item.title}}</view>
  <view class="muted">{{item.created_at}} · {{item.start_time || '开头'}} → {{item.end_time || '结尾'}}</view>
</view>

.hero {
  display: flex;
  align-items: center;
  gap: 20rpx;
  padding: 36rpx 28rpx 16rpx;
}

.icon {
  width: 72rpx;
  height: 72rpx;
}

.title {
  font-size: 40rpx;
  font-weight: 700;
}

.welcome {
  margin-top: 12rpx;
}

.section-title {
  font-size: 32rpx;
  font-weight: 700;
  margin-bottom: 12rpx;
}

.list-title {
  margin: 28rpx 24rpx 8rpx;
}

.primary,
.secondary,
.plain {
  margin-top: 18rpx;
  border-radius: 8rpx;
  font-size: 30rpx;
}

.primary {
  background: #0071e3;
  color: #ffffff;
}

.secondary {
  background: #ffffff;
  color: #102033;
  border: 1px solid #dbe3ee;
}

.plain {
  background: #ffffff;
  color: #64748b;
}

.project-title {
  font-size: 32rpx;
  font-weight: 600;
  margin-bottom: 8rpx;
}

<view class="study-head">
  <view class="title">{{project.title}}</view>
  <view class="muted">{{project.created_at}} · {{project.start_time || '开头'}} → {{project.end_time || '结尾'}}</view>
</view>

<view class="card player">
  <view class="companion">
    <image class="mascot" src="/assets/briba-icon.svg" mode="aspectFit" />
    <view class="companion-copy">
      <view class="companion-title">{{playing ? 'BriBa 正在陪你精听' : 'BriBa 准备好了'}}</view>
      <view class="companion-subtitle">{{currentSubtitle.text ? '跟着这一句慢慢听。' : '点击字幕或播放音频开始。'}}</view>
    </view>
    <view class="play-orb" bindtap="toggleAudio" aria-label="{{playing ? '暂停' : '播放'}}">{{playing ? 'Ⅱ' : '▶'}}</view>
  </view>
  <view class="option-row">
    <button class="chip {{showCurrentLine ? 'active' : ''}}" bindtap="toggleCurrentLine">{{showCurrentLine ? '隐藏单句' : '显示单句'}}</button>
    <button class="chip {{showTranslation ? 'active' : ''}}" bindtap="toggleTranslation">{{showTranslation ? '隐藏中文' : '显示中文'}}</button>
    <view class="sync-tools">
      <text class="sync-label">字幕延后</text>
      <button class="chip" bindtap="delayDown">-</button>
      <text class="sync-value">{{subtitleDelayLabel}}</text>
      <button class="chip" bindtap="delayUp">+</button>
    </view>
  </view>
  <view wx:if="{{showCurrentLine}}" class="current-line">
    <view>{{currentSubtitle.text || '点击字幕或播放音频开始精听。'}}</view>
    <view wx:if="{{showTranslation && currentSubtitle.translation}}" class="translation-text">{{currentSubtitle.translation}}</view>
  </view>
  <view class="tools">
    <button bindtap="prevLine">上一句</button>
    <button bindtap="replayLine">重听</button>
    <button bindtap="nextLine">下一句</button>
  </view>
</view>

<view class="card">
  <view class="fold-head" bindtap="toggleNotes">
    <view>
      <view class="section-title">学习笔记</view>
      <view class="note-hint">本机保存，可以随时补充你的理解。</view>
    </view>
    <button class="chip">{{notesCollapsed ? '展开' : '折叠'}}</button>
  </view>
  <textarea
    wx:if="{{!notesCollapsed}}"
    class="note-editor"
    value="{{notes}}"
    placeholder="写下这一集里值得记住的表达、语法或发音提醒。"
    maxlength="-1"
    auto-height
    bindinput="onNotesInput"
  />
</view>

<view class="subtitle-head">
  <view class="section-title">字幕精听</view>
  <button class="chip" bindtap="toggleTranscript">{{transcriptCollapsed ? '展开字幕' : '折叠字幕'}}</button>
</view>
<view wx:if="{{!transcriptCollapsed}}">
  <view wx:for="{{subtitleItems}}" wx:key="index" class="card subtitle-line {{index === currentSubtitleIndex ? 'active' : ''}}" data-index="{{index}}" bindtap="jumpToLine">
    <view class="muted">{{item.startLabel}} → {{item.endLabel}}</view>
    <view class="line-text">{{item.text}}</view>
    <view wx:if="{{showTranslation && item.translation}}" class="translation-text">{{item.translation}}</view>
  </view>
</view>

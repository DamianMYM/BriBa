.study-head {
  padding: 28rpx 28rpx 8rpx;
}

.title {
  font-size: 36rpx;
  font-weight: 700;
  margin-bottom: 8rpx;
  color: #1d1d1f;
}

.section-title {
  font-size: 30rpx;
  font-weight: 700;
  margin-bottom: 12rpx;
}

.list-title {
  margin: 28rpx 24rpx 8rpx;
}

.player {
  position: sticky;
  top: 0;
  z-index: 2;
  box-shadow: 0 12rpx 34rpx rgba(0, 0, 0, 0.05);
}

.companion {
  display: grid;
  grid-template-columns: 92rpx 1fr 68rpx;
  align-items: center;
  gap: 16rpx;
}

.mascot {
  width: 92rpx;
  height: 92rpx;
}

.companion-title {
  font-size: 30rpx;
  font-weight: 700;
  color: #1d1d1f;
}

.companion-subtitle {
  margin-top: 6rpx;
  color: #6e6e73;
  font-size: 24rpx;
  line-height: 1.4;
}

.play-orb {
  width: 64rpx;
  height: 64rpx;
  line-height: 64rpx;
  border-radius: 50%;
  background: #35c2a8;
  color: #ffffff;
  font-size: 26rpx;
  font-weight: 700;
  text-align: center;
  box-shadow: 0 8rpx 18rpx rgba(53, 194, 168, 0.22);
}

.option-row {
  display: grid;
  grid-template-columns: 1fr;
  gap: 14rpx;
  margin-top: 20rpx;
  color: #6e6e73;
  font-size: 24rpx;
}

.sync-tools {
  display: grid;
  grid-template-columns: auto 1fr auto 1fr;
  align-items: center;
  gap: 8rpx;
}

.chip {
  min-height: 56rpx;
  line-height: 56rpx;
  margin: 0;
  padding: 0 20rpx;
  border-radius: 8rpx;
  background: #f7f7f9;
  color: #424245;
  border: 1px solid #e8e8ed;
  font-size: 24rpx;
  white-space: nowrap;
}

.chip.active {
  background: #e8f7f3;
  color: #08705b;
  border-color: #b7e7d9;
}

.sync-tools .chip {
  background: #ffffff;
  color: #1d1d1f;
}

.sync-tools .chip:active,
.tools button:active,
.play-orb:active {
  opacity: 0.78;
}

.sync-label {
  color: #6e6e73;
}

.sync-value {
  min-width: 76rpx;
  text-align: center;
  color: #6e6e73;
  font-variant-numeric: tabular-nums;
}

.tools {
  display: flex;
  gap: 12rpx;
  margin-top: 16rpx;
}

.tools button {
  flex: 1;
  background: #ffffff;
  color: #1d1d1f;
  border: 1px solid #e8e8ed;
  border-radius: 8rpx;
  font-size: 26rpx;
}

.current-line {
  margin-top: 18rpx;
  padding: 22rpx;
  border-left: 8rpx solid #35c2a8;
  border-radius: 8rpx;
  background: #effaf7;
  color: #08705b;
  line-height: 1.6;
  min-height: 76rpx;
}

.fold-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
}

.fold-head .section-title {
  margin-bottom: 0;
}

.note-hint {
  margin-top: 6rpx;
  color: #8a8a8e;
  font-size: 24rpx;
}

.note-editor {
  width: 100%;
  min-height: 180rpx;
  box-sizing: border-box;
  margin-top: 18rpx;
  padding: 20rpx;
  border-radius: 8rpx;
  background: #fbfbfd;
  border: 1px solid #e8e8ed;
  line-height: 1.65;
  font-size: 28rpx;
  color: #424245;
}

.subtitle-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin: 28rpx 24rpx 8rpx;
}

.subtitle-head .section-title {
  margin-bottom: 0;
}

.subtitle-line {
  padding-top: 20rpx;
  padding-bottom: 20rpx;
}

.subtitle-line.active {
  border-color: #b7e7d9;
  background: #effaf7;
}

.line-text {
  margin-top: 8rpx;
  line-height: 1.58;
  font-size: 30rpx;
  color: #1d1d1f;
}

.translation-text {
  margin-top: 10rpx;
  line-height: 1.55;
  font-size: 27rpx;
  color: #08705b;
}
